BOT_TOKEN=your-telegram-bot-token
BOT_OWNER_IDS=
OPENAI_APIKEY=your-openai-api-key
OPENAI_API_MODE=responses
SPRING_PROFILES_ACTIVE=dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=tgbotgpt

# Optional: override default local datasource
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tgbotgpt
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your-postgres-password

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
ENCRYPTION_REQUIRED=false

# Optional: actuator is bound to localhost:8081 by default.
# In prod only /actuator/health is exposed.
# MANAGEMENT_SERVER_PORT=8081
# MANAGEMENT_SERVER_ADDRESS=127.0.0.1

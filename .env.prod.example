BOT_TOKEN=your-telegram-bot-token
BOT_OWNER_IDS=your-telegram-user-id
BOT_WHITELIST=

OPENAI_APIKEY=your-openai-api-key
OPENAI_API_MODE=responses
OPENAI_MODEL=gpt-5.4-nano
OPENAI_ALLOWED_MODELS=gpt-5.4-nano,gpt-5.4-mini,gpt-4o-mini,gpt-4o
OPENAI_MAX_HISTORY_TOKENS=2000

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/tgbotgpt
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tgbotgpt
BILLING_DEFAULT_PLAN=free
BILLING_FREE_MONTHLY_TOKENS=50000
BILLING_FREE_MONTHLY_MESSAGES=100
BILLING_PRO_MONTHLY_TOKENS=1000000
BILLING_PRO_MONTHLY_MESSAGES=2000

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-32-byte-key
ENCRYPTION_REQUIRED=true

MANAGEMENT_SERVER_PORT=8081
MANAGEMENT_SERVER_ADDRESS=127.0.0.1
